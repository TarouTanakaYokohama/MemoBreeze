{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "MemoBreeze",
	"version": "0.1.0",
	"identifier": "com.tarou.MemoBreeze",
	"build": {
		"beforeDevCommand": "bun run dev",
		"devUrl": "http://localhost:1420",
		"beforeBuildCommand": "bun run build",
		"frontendDist": "../dist"
	},
	"app": {
		"windows": [
			{
				"title": "MemoBreeze",
				"width": 800,
				"height": 600
			}
		],
		"security": {
			"csp": null
		}
	},
	"bundle": {
		"active": true,
		"targets": "all",
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		],
		"macOS": {
			"minimumSystemVersion": "14.2",
			"files": {
				"Frameworks/libvosk.dylib": "libs/macos/libvosk.dylib",
				"MacOS/libvosk.dylib": "libs/macos/libvosk.dylib"
			},
			"frameworks": ["./libs/macos/libvosk.dylib"]
		}
	}
}
