{
	"name": "MemoBreeze",
	"private": true,
	"version": "0.1.0",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "tsc && vite build",
		"preview": "vite preview",
		"tauri": "tauri",
		"format": "biome format --write .",
		"lint": "biome lint --write .",
		"check": "biome check --write .",
		"quality": "bun run format && bun run lint && bun run check && bun run test && bun run build && bun run format:rust && bun run lint:rust",
		"format:rust": "cd src-tauri && cargo fmt",
		"lint:rust": "cd src-tauri && cargo clippy -- -D warnings",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"audit:rust": "cd src-tauri && cargo audit"
	},
	"dependencies": {
		"@radix-ui/react-dialog": "^1.1.15",
		"@radix-ui/react-label": "^2.1.8",
		"@radix-ui/react-scroll-area": "^1.2.10",
		"@radix-ui/react-select": "^2.2.6",
		"@radix-ui/react-switch": "^1.2.6",
		"@radix-ui/react-tabs": "^1.1.13",
		"@tauri-apps/api": "^2.10.1",
		"@tauri-apps/plugin-dialog": "~2.6.0",
		"@tauri-apps/plugin-global-shortcut": "^2.3.1",
		"@tauri-apps/plugin-opener": "^2.5.3",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"i18next": "^25.8.7",
		"i18next-browser-languagedetector": "^8.2.1",
		"lucide-react": "^0.564.0",
		"nanoid": "^5.1.6",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"react-i18next": "^16.5.4",
		"tailwind-merge": "^3.4.0",
		"zustand": "^5.0.11",
		"react-error-boundary": "^5.0.0"
	},
	"devDependencies": {
		"@biomejs/biome": "2.3.15",
		"@tauri-apps/cli": "^2",
		"@types/node": "^25.2.3",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^4.3",
		"autoprefixer": "^10.4.24",
		"npm-check-updates": "^19.3.2",
		"postcss": "^8.5.6",
		"shadcn": "^3.8.4",
		"tailwindcss": "^3.4",
		"tailwindcss-animate": "^1.0.7",
		"typescript": "~5.9.3",
		"vite": "^7.3.1",
		"@testing-library/jest-dom": "^6.6.3",
		"@testing-library/react": "^16.3.0",
		"jsdom": "^25.0.1",
		"vitest": "^2.1.8",
		"@vitest/coverage-v8": "^2.1.8"
	}
}
